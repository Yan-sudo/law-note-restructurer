{
    "name": "law-note-restructurer",
    "version": "0.1.0",
    "description": "AI-powered restructuring of legal notes for Obsidian",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "typecheck": "tsc -noEmit -skipLibCheck",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src tests",
        "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
    },
    "devDependencies": {
        "@eslint/js": "^9.9.0",
        "@types/node": "^20.0.0",
        "builtin-modules": "^3.3.0",
        "esbuild": "^0.21.0",
        "eslint": "^9.9.0",
        "globals": "^15.9.0",
        "obsidian": "latest",
        "prettier": "^3.3.0",
        "typescript": "^5.4.0",
        "typescript-eslint": "^8.0.0",
        "vitest": "^2.1.0",
        "@vitest/coverage-v8": "^2.1.0"
    },
    "dependencies": {
        "@google/genai": "^1.0.0",
        "mammoth": "^1.8.0",
        "zod": "^3.23.0"
    }
}
